<Window
    x:Class="BMS_Clone.Views.Dialog.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Width="350"
    Height="400"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">


    <Border
        Background="#333333"
        BorderBrush="Yellow"
        BorderThickness="0.5"
        CornerRadius="10">


        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="120" />
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>


            <!--  Login Icon  -->
            <iconPacks:PackIconMaterial
                Grid.Row="0"
                Width="90"
                Height="90"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                Kind="Alien" />


            <!--  Title  -->
            <TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Footlight MT Light"
                FontSize="25"
                FontWeight="Bold"
                Foreground="White"
                Text="L O G I N   N O W" />


            <!--  Form  -->
            <StackPanel
                Grid.Row="2"
                Margin="35,20"
                VerticalAlignment="Center">


                <TextBlock
                    FontFamily="Footlight MT Light"
                    FontSize="15"
                    Foreground="White"
                    Text="Username" />

                <TextBox
                    Height="35"
                    Margin="0,5,0,15"
                    FontSize="15"
                    Style="{StaticResource LoginTextBoxStyle}"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    FontFamily="Footlight MT Light"
                    FontSize="15"
                    Foreground="White"
                    Text="Password" />

                <PasswordBox
                    x:Name="PasswordBox"
                    Height="35"
                    Margin="0,5"
                    FontSize="15"
                    Style="{StaticResource LoginPasswordBoxStyle}" />

            </StackPanel>


            <!--  Buttons  -->
            <Grid Grid.Row="3">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>


                <Button
                    Grid.Column="0"
                    Command="{Binding CancelCommand}"
                    Content="Cancel"
                    Style="{StaticResource ButtonStyle}" />


                <Button
                    Grid.Column="1"
                    Command="{Binding LoginCommand}"
                    Content="Login"
                    Style="{StaticResource ButtonStyle}" />

            </Grid>


        </Grid>

    </Border>

</Window>