<Window
    x:Class="BMS_Clone.Views.Dialog.TopUpHistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:BMS_Clone.Views.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Top Up History"
    Width="650"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <Border
        Background="#505050"
        BorderBrush="Yellow"
        BorderThickness="0.5">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="9*" />
                <RowDefinition Height="76*" />
                <RowDefinition Height="471*" />
            </Grid.RowDefinitions>


            <Grid Grid.Row="0" Background="#2E2E2E">

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Footlight MT Light"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Top Up History" />

            </Grid>

            <Grid
                Grid.Row="1"
                Grid.RowSpan="4"
                Background="#2E2E2E">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">

                    <Border BorderBrush="#555555" BorderThickness="0,0,1,0" />

                    <DockPanel>

                        <StackPanel Margin="0,15,0,0" DockPanel.Dock="Top">

                            <Grid
                                Width="110"
                                Height="110"
                                HorizontalAlignment="Center">

                                <Ellipse
                                    Fill="#444444"
                                    Stroke="#777777"
                                    StrokeThickness="1" />

                                <iconPacks:PackIconMaterial
                                    Width="70"
                                    Height="70"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#666666"
                                    Kind="Account" />

                            </Grid>

                            <TextBlock
                                Margin="0,10,0,10"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Text="User" />

                            <Separator
                                Height="1"
                                Margin="0"
                                Background="#555555" />

                        </StackPanel>

                        <ListBox
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListBoxItem Style="{StaticResource SidebarListBoxItemStyle}">
                                <Button
                                    Height="35"
                                    Padding="15,0"
                                    VerticalContentAlignment="Center"
                                    Content="dev"
                                    Style="{StaticResource SidebarButtonStyle}" />
                            </ListBoxItem>

                            <ListBoxItem Style="{StaticResource SidebarListBoxItemStyle}">
                                <Button
                                    Height="35"
                                    Padding="15,0"
                                    VerticalContentAlignment="Center"
                                    Content="pilot001"
                                    Style="{StaticResource SidebarButtonStyle}" />
                            </ListBoxItem>


                        </ListBox>

                    </DockPanel>

                </Grid>

                <Grid Grid.Column="1" Margin="15,10,15,10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Border
                                Width="40"
                                Height="20"
                                Margin="0,0,8,0"
                                Background="#444444"
                                BorderBrush="#555555"
                                BorderThickness="1"
                                CornerRadius="10">
                                <Ellipse
                                    Width="14"
                                    Height="14"
                                    Margin="3,0"
                                    HorizontalAlignment="Left"
                                    Fill="#FFC107" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="#888888"
                                Text="Unblock" />
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            Margin="0,0,10,0"
                            Background="#3A3A3A"
                            Command="{Binding CloseCommand}"
                            Content="Close"
                            Style="{StaticResource ButtonStyle}" />
                        <Button
                            Grid.Column="3"
                            Background="#3A3A3A"
                            Content="Save"
                            Style="{StaticResource ButtonStyle}" />
                    </Grid>

                </Grid>

            </Grid>

            <Grid />

        </Grid>


    </Border>

</Window>
