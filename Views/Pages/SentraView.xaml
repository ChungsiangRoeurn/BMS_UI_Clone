<UserControl
    x:Class="BMS_Clone.Views.Pages.SentraView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:BMS_Clone.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="250" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Row="0"
                Padding="10"
                Background="#333333"
                BorderBrush="Yellow"
                BorderThickness="0.5"
                CornerRadius="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Temperature" />

                    <TextBlock
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="40"
                        Foreground="White"
                        Text="25°C" />

                    <Button
                        Grid.Row="2"
                        Width="120"
                        Height="35"
                        Content="View Detail"
                        Style="{StaticResource ButtonStyle}" />
                </Grid>

            </Border>

            <Border
                Grid.Column="2"
                Padding="10"
                Background="#333333"
                BorderBrush="Yellow"
                BorderThickness="0.5"
                CornerRadius="10">

                <Border
                    Width="220"
                    Padding="16"
                    Background="#2D2D30"
                    BorderBrush="#3F3F46"
                    BorderThickness="1"
                    CornerRadius="12"
                    Effect="{DynamicResource DropShadowEffect}">
                    <!--  Optional: Adds depth  -->

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  Fits text perfectly  -->
                            <RowDefinition Height="Auto" />
                            <!--  Fits icon perfectly  -->
                            <RowDefinition Height="Auto" />
                            <!--  Fits button perfectly  -->
                        </Grid.RowDefinitions>

                        <!--  Title  -->
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Lamborghini" />

                        <!--  Icon  -->
                        <iconPacks:PackIconMaterial
                            Grid.Row="1"
                            Width="56"
                            Height="56"
                            Margin="0,0,0,24"
                            HorizontalAlignment="Center"
                            Foreground="#107C41"
                            Kind="Car" />

                        <!--  Action Button  -->
                        <Button
                            Grid.Row="2"
                            Width="100"
                            Height="22"
                            Content="View details" />

                    </Grid>
                </Border>

            </Border>

            <Border
                Grid.Column="4"
                Background="Pink"
                CornerRadius="10" />

            <Border
                Grid.Column="6"
                Background="Orange"
                CornerRadius="10" />

        </Grid>
        <Border
            Grid.Row="2"
            Background="Yellow"
            CornerRadius="10" />

    </Grid>
</UserControl>
