<UserControl
    x:Class="BMS_Clone.Views.Pages.GridView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:BMS_Clone.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BMS_Clone.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="#252525"
    mc:Ignorable="d">

    <Grid>

        <TabControl Background="Transparent">

            <TabItem Header="Ground Floor" Style="{StaticResource GridTabItem}">

                <Grid Margin="15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="320" />
                        <RowDefinition Height="150" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="450" />
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            BorderBrush="#FFD54F"
                            BorderThickness="1"
                            CornerRadius="10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>


                                <!--  Car Image Area  -->
                                <Border
                                    Grid.Column="0"
                                    Background="#252525"
                                    CornerRadius="10">

                                    <Image
                                        Width="250"
                                        Height="320"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Source="{Binding CarImage}"
                                        Stretch="Uniform" />

                                </Border>

                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                    <Button
                                        Width="40"
                                        Height="40"
                                        Margin="5"
                                        Background="Red"
                                        Command="{Binding RedCommand}"
                                        Style="{StaticResource ButtonStyle}" />


                                    <Button
                                        Width="40"
                                        Height="40"
                                        Margin="5"
                                        Background="Blue"
                                        Command="{Binding BlueCommand}"
                                        Style="{StaticResource ButtonStyle}" />


                                    <Button
                                        Width="40"
                                        Height="40"
                                        Margin="5"
                                        Background="Black"
                                        Command="{Binding BlackCommand}"
                                        Style="{StaticResource ButtonStyle}" />


                                    <Button
                                        Width="40"
                                        Height="40"
                                        Margin="5"
                                        Background="White"
                                        Command="{Binding WhiteCommand}"
                                        Style="{StaticResource ButtonStyle}" />


                                    <Button
                                        Width="40"
                                        Height="40"
                                        Margin="5"
                                        Background="Gold"
                                        Command="{Binding YellowCommand}"
                                        Style="{StaticResource ButtonStyle}" />


                                </StackPanel>



                            </Grid>

                        </Border>
                        <!--  Information  -->

                        <Border
                            Grid.Column="2"
                            Padding="25"
                            Background="#333333"
                            BorderBrush="#FFD54F"
                            BorderThickness="1"
                            CornerRadius="10">

                            <StackPanel>
                                <TextBlock
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="Ground Floor" />

                                <Separator Margin="0,15" />

                                <TextBlock
                                    Margin="0,6"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Building : Tesla Factory" />
                                <TextBlock
                                    Margin="0,6"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Floor : Ground Floor" />
                                <TextBlock
                                    Margin="0,6"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Total Meter : 24" />
                                <TextBlock
                                    Margin="0,6"
                                    FontSize="16"
                                    Foreground="#4CAF50"
                                    Text="Online : 22" />
                                <TextBlock
                                    Margin="0,6"
                                    FontSize="16"
                                    Foreground="#FF9800"
                                    Text="Offline : 2" />
                                <TextBlock
                                    Margin="0,6"
                                    FontSize="16"
                                    Foreground="#8BC34A"
                                    Text="Alarm : Normal" />
                            </StackPanel>

                        </Border>

                    </Grid>

                    <UniformGrid
                        Grid.Row="1"
                        Margin="0,15,0,15"
                        Columns="4">

                        <Border
                            Margin="8"
                            Background="#333333"
                            BorderBrush="#FFD54F"
                            BorderThickness="1"
                            CornerRadius="10">

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Total Meter" />

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="24" />

                            </StackPanel>

                        </Border>

                        <Border
                            Margin="8"
                            Background="#333333"
                            BorderBrush="#FFD54F"
                            BorderThickness="1"
                            CornerRadius="10">

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Foreground="LimeGreen"
                                    Text="Online" />

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="22" />

                            </StackPanel>

                        </Border>


                        <Border
                            Margin="8"
                            Background="#333333"
                            BorderBrush="#FFD54F"
                            BorderThickness="1"
                            CornerRadius="10">

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Offline" />

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Foreground="Orange"
                                    Text="2" />

                            </StackPanel>

                        </Border>

                        <Border
                            Margin="8"
                            Background="#333333"
                            BorderBrush="#FFD54F"
                            BorderThickness="1"
                            CornerRadius="10">

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Foreground="White"
                                    Text="Alarm" />

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Foreground="Red"
                                    Text="0" />

                            </StackPanel>

                        </Border>

                    </UniformGrid>


                    <Border
                        Grid.Row="2"
                        Padding="10"
                        Background="#333333"
                        BorderBrush="#FFD54F"
                        BorderThickness="1"
                        CornerRadius="10" />

                </Grid>

            </TabItem>


            <TabItem Header="West Ground Floow" Style="{StaticResource GridTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Width="1000"
                        Height="45"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="#1E293B"
                        CornerRadius="10">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Button
                                Grid.Column="0"
                                Margin="8"
                                Command="{Binding GoSentraCommand}"
                                Content="Nissan Sentra"
                                Style="{StaticResource NavBtnStyle}" />

                            <Button
                                Grid.Column="1"
                                Margin="8"
                                Command="{Binding GoLeafCommand}"
                                Content="Nissan Leaf"
                                Style="{StaticResource NavBtnStyle}" />

                            <Button
                                Grid.Column="2"
                                Margin="8"
                                Command="{Binding GoKiaCommand}"
                                Content="Kia Telluride"
                                Style="{StaticResource NavBtnStyle}" />

                            <Button
                                Grid.Column="3"
                                Margin="8"
                                Command="{Binding GoPorscheCommand}"
                                Content="Porsche 911"
                                Style="{StaticResource NavBtnStyle}" />

                            <Button
                                Grid.Column="4"
                                Margin="8"
                                Command="{Binding GoLamboCommand}"
                                Content="Lamborghini"
                                Style="{StaticResource NavBtnStyle}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1">
                        <ContentControl Content="{Binding CurrentPage}" />
                    </Border>
                </Grid>
            </TabItem>


            <TabItem Header="Warehouse-Floor" Style="{StaticResource GridTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>


                        <Border
                            Width="350"
                            Height="40"
                            Background="#334155"
                            BorderBrush="#475569"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Style="{StaticResource IconButtonStyle}">

                                    <iconPacks:PackIconMaterial
                                        Width="16"
                                        Height="16"
                                        Foreground="White"
                                        Kind="Magnify" />

                                </Button>

                                <TextBox
                                    Grid.Column="1"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="15"
                                    Foreground="White"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource IconButtonStyle}">
                                    <iconPacks:PackIconMaterial
                                        Width="12"
                                        Height="12"
                                        Foreground="White"
                                        Kind="Close" />
                                </Button>
                            </Grid>

                        </Border>

                        <!--  Profile  -->
                        <Grid Grid.Column="3" Width="100">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="40"
                                Height="40"
                                Background="#334155"
                                BorderBrush="White"
                                BorderThickness="0.5"
                                CornerRadius="10">
                                <Button
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource IconButtonStyle}">
                                    <iconPacks:PackIconMaterial
                                        Width="24"
                                        Height="24"
                                        Foreground="White"
                                        Kind="Account" />
                                </Button>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Width="40"
                                Height="40"
                                Background="#334155"
                                BorderBrush="White"
                                BorderThickness="0.5"
                                CornerRadius="10">
                                <Button
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource IconButtonStyle}">
                                    <iconPacks:PackIconMaterial
                                        Width="24"
                                        Height="24"
                                        Foreground="White"
                                        Kind="Bell" />
                                </Button>
                            </Border>
                        </Grid>
                    </Grid>

                    <ScrollViewer
                        Grid.Row="3"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Hidden">

                        <ItemsControl ItemsSource="{Binding Products}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="10"
                                        Padding="15"
                                        Background="#2C2C2C"
                                        BorderBrush="#555"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Image
                                                Width="120"
                                                Height="120"
                                                Source="{Binding Thumbnail}"
                                                Stretch="Uniform" />

                                            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                                <TextBlock
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding Title}" />

                                                <TextBlock
                                                    FontSize="14"
                                                    Foreground="LightGray"
                                                    Text="{Binding Brand}" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    Foreground="#7DD3FC"
                                                    Text="{Binding Category}" />

                                                <TextBlock
                                                    MaxHeight="40"
                                                    Foreground="Gray"
                                                    Text="{Binding Description}"
                                                    TextWrapping="Wrap" />

                                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                    <TextBlock
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Foreground="#4ADE80"
                                                        Text="{Binding Price, StringFormat='${0:F2}'}" />

                                                    <TextBlock
                                                        Margin="20,0,0,0"
                                                        Foreground="Yellow"
                                                        Text="{Binding Rating, StringFormat=' ⭐ {0}'}" />

                                                    <TextBlock
                                                        Margin="20,0,0,0"
                                                        Foreground="White"
                                                        Text="{Binding Stock, StringFormat=' Stock: {0}'}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>

    </Grid>

</UserControl>