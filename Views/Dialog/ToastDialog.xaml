<Window
    x:Class="BMS_Clone.Views.Dialog.ToastDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BMS_Clone.Views.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ToastDialog"
    Width="360"
    Height="100"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None"
    mc:Ignorable="d">

    <Border Margin="10">

        <Border
            Padding="16,0"
            Background="#232323"
            BorderBrush="Yellow"
            BorderThickness="0.5"
            CornerRadius="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="4"
                    Height="40"
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    Background="{Binding AccentColor}"
                    CornerRadius="1" />

                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        FontFamily="Footlight MT Light"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="#FFFFFF"
                        Text="{Binding Title}" />

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,5,0,0"
                        FontFamily="Footlight MT Light"
                        FontSize="14"
                        Foreground="#A0A0A0"
                        Text="{Binding Message}"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>