<Window
    x:Class="BMS_Clone.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:viewmodels="clr-namespace:BMS_Clone.ViewModels"
    Width="1300"
    Height="800"
    Background="#261F1F"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border BorderBrush="Yellow" BorderThickness="0.5">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Sidebar  -->
                <Border Grid.Column="0" Background="#505050">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="230" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>

                        <!--  Profile Area  -->
                        <Border Grid.Row="0">

                            <Grid>

                                <Button
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding OpenSettingCommand}"
                                    Cursor="Hand"
                                    Style="{StaticResource IconButtonStyle}">

                                    <iconPacks:PackIconMaterial
                                        Width="20"
                                        Height="20"
                                        Foreground="White"
                                        Kind="Cog" />

                                </Button>

                                <!--  Profile Content  -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                                    <Border
                                        Width="160"
                                        Height="160"
                                        Background="#404040"
                                        BorderBrush="White"
                                        BorderThickness="2"
                                        CornerRadius="90">

                                        <iconPacks:PackIconMaterial
                                            Width="100"
                                            Height="100"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="White"
                                            Kind="Account" />

                                    </Border>

                                    <TextBlock
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Admin Dashboard" />

                                </StackPanel>

                            </Grid>

                        </Border>

                        <!--  Sidebar Menu  -->
                        <ScrollViewer
                            Grid.Row="1"
                            Background="#505050"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Hidden">
                            <StackPanel Grid.Row="1" Background="#505050">

                                <Button Command="{Binding GoMonitorMeterCommand}" Style="{StaticResource SidebarButtonStyle}">

                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            VerticalAlignment="Center"
                                            Kind="Gauge" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Monitor Meter" />

                                    </StackPanel>

                                </Button>

                                <!--  Grid View  -->
                                <Button Command="{Binding GoGridViewCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            VerticalAlignment="Center"
                                            Kind="ViewDashboard" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Grid View" />
                                    </StackPanel>
                                </Button>

                                <!--  Top Up Balance  -->
                                <Button Command="{Binding GoTopUpBalanceCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="CashPlus" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Top Up Balance" />
                                    </StackPanel>
                                </Button>

                                <!--  Top Up History  -->
                                <Button Command="{Binding GoTopUpHistoryCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="History" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Top Up History" />
                                    </StackPanel>
                                </Button>

                                <!--  Alarm  -->
                                <Button Command="{Binding GoAlarmCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="AlarmLight" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Alarm" />
                                    </StackPanel>
                                </Button>


                                <!--  Alarm Event  -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="AlertCircle" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Alarm Event" />
                                    </StackPanel>
                                </Button>

                                <!--  Notification  -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="Bell" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Notification" />
                                    </StackPanel>
                                </Button>

                                <!--  Notification Events  -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="BellAlert" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Notification Events" />
                                    </StackPanel>
                                </Button>

                                <!--  Consumptions  -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="ChartLine" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Consumptions" />
                                    </StackPanel>
                                </Button>

                                <!--  Monitor Controller  -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="MonitorDashboard" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="Monitor Controller" />
                                    </StackPanel>
                                </Button>

                                <!--  User Log  -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="22"
                                            Height="22"
                                            Kind="AccountClock" />

                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="User Log" />
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>

                        <!--  Logout Area  -->
                        <Border Grid.Row="2">
                            <Button Command="{Binding LogoutCommand}" Style="{StaticResource SidebarButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="22"
                                        Height="22"
                                        Kind="Logout" />

                                    <TextBlock
                                        Margin="15,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="Logout" />
                                </StackPanel>
                            </Button>
                        </Border>

                    </Grid>

                </Border>

                <!--  Content Area  -->
                <Border Grid.Column="1" Background="#303030">
                    <Border.Resources>
                        <!--  Style for the main Menu bar background  -->
                        <Style TargetType="Menu">
                            <Setter Property="Background" Value="#252525" />
                            <Setter Property="Foreground" Value="White" />
                        </Style>

                        <!--  Style to center text and color all MenuItems  -->
                        <Style TargetType="MenuItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />

                            <Setter Property="FontFamily" Value="Footlight MT Light" />
                            <Setter Property="FontSize" Value="16" />
                            <Setter Property="Foreground" Value="WhiteSmoke" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Background" Value="#252525" />


                            <Setter Property="Padding" Value="15,5,15,5" />
                        </Style>
                    </Border.Resources>

                    <DockPanel>
                        <Menu Height="30" DockPanel.Dock="Top">

                            <MenuItem Header="File" Style="{StaticResource TopMenuItemStyle}">

                                <MenuItem
                                    Command="{Binding LogoutCommand}"
                                    Header="Logout"
                                    Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem
                                    Command="{Binding CloseCommand}"
                                    Header="Close"
                                    Style="{StaticResource TopMenuItemStyle}" />

                            </MenuItem>


                            <MenuItem Header="User" Style="{StaticResource TopMenuItemStyle}">

                                <MenuItem Header="Cut" Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem Header="Copy" Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem Header="Paste" Style="{StaticResource TopMenuItemStyle}" />

                            </MenuItem>


                            <MenuItem Header="Device" Style="{StaticResource TopMenuItemStyle}">

                                <MenuItem Header="All Meters" Style="{StaticResource TopMenuItemStyle}" />

                            </MenuItem>


                            <MenuItem Header="Property" Style="{StaticResource TopMenuItemStyle}">

                                <MenuItem Header="All Building" Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem Header="Create Building" Style="{StaticResource TopMenuItemStyle}" />

                            </MenuItem>


                            <MenuItem Header="Tanent" Style="{StaticResource TopMenuItemStyle}">

                                <MenuItem Header="All Tanent" Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem Header="Create Tanent" Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem Header="Modify Tanent" Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem Header="Low Balance Warning" Style="{StaticResource TopMenuItemStyle}" />

                            </MenuItem>


                            <MenuItem Header="Help" Style="{StaticResource TopMenuItemStyle}">

                                <MenuItem Header="All Building" Style="{StaticResource TopMenuItemStyle}" />

                                <MenuItem Header="Create Building" Style="{StaticResource TopMenuItemStyle}" />

                            </MenuItem>

                        </Menu>

                        <Grid x:Name="MainContent">
                            <ContentControl Content="{Binding CurrentView}" />
                        </Grid>
                    </DockPanel>
                </Border>

                <Border
                    x:Name="DialogOverlay"
                    Panel.ZIndex="100"
                    Background="#66000000"
                    Opacity="0"
                    Visibility="Collapsed">

                    <Border.Effect>
                        <BlurEffect Radius="10" />
                    </Border.Effect>

                </Border>

            </Grid>

            <!--  Bottom Title Bar  -->
            <Border Grid.Row="1" Background="#1E1E1E">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>


                    <TextBlock
                        Margin="10,0"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="BMS Clone" />


                    <Button
                        Grid.Column="1"
                        Click="Minimize_Click"
                        Style="{StaticResource TitleButtonStyle}">
                        <iconPacks:PackIconMaterial
                            Width="12"
                            Height="12"
                            Foreground="White"
                            Kind="WindowMinimize" />
                    </Button>


                    <Button
                        Grid.Column="2"
                        Click="Maximize_Click"
                        Style="{StaticResource TitleButtonStyle}">
                        <iconPacks:PackIconMaterial
                            Width="12"
                            Height="12"
                            Foreground="White"
                            Kind="WindowMaximize" />
                    </Button>


                    <Button
                        Grid.Column="3"
                        Click="Close_Click"
                        Style="{StaticResource CloseButtonStyle}">
                        <iconPacks:PackIconMaterial
                            Width="12"
                            Height="12"
                            Foreground="White"
                            Kind="Close" />
                    </Button>


                </Grid>

            </Border>

        </Grid>

    </Border>

</Window>